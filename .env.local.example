# ── AI (report generation) ──
# Get a key at https://console.anthropic.com/
# Without this, the app runs in demo mode (returns a canned report).
ANTHROPIC_API_KEY=sk-ant-...

# ── Storage backend + auth (optional) ──
# Leave these blank to use localStorage (default — no account, no login).
# To enable cloud storage AND email/password auth: create a Supabase project,
# run supabase/schema.sql in the SQL editor, then fill both values below.
# When set, the app routes through /login and scopes data per user via RLS.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
